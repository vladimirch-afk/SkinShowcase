<?xml version="1.0" encoding="utf-8"?>
<!--
  HTTP (cleartext) для api-gateway при разработке.
  Эмулятор: 10.0.2.2 → localhost на хосте (например :8080).
  Реальное устройство: укажи IP компа в сети (192.168.x.x) в ApiConfig.
-->
<network-security-config>
    <!-- Явно разрешаем cleartext для хоста api-gateway -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
    </domain-config>
    <!-- Для разработки: разрешить HTTP на любой хост (в т.ч. LAN IP 192.168.x.x).
        В production лучше удалить и использовать только HTTPS. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
